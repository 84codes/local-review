#!/usr/bin/env bash
set -euo pipefail

# local-review: AI-powered local code review for git repos.
# Subcommands: setup, install, review, hook

PROG="local-review"
VERSION="0.1.0"
SCRIPT_DIR=$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)

# --- Shared helpers ---

find_repo_root() {
  git rev-parse --show-toplevel 2>/dev/null || {
    echo "Not inside a git repository." >&2
    exit 1
  }
}

resolve_backend() {
  local root="$1"
  # 1. CLI flag (set via REVIEWER before calling)
  # 2. Environment variable
  if [[ -n "${REVIEWER:-}" ]]; then
    echo "$REVIEWER"
    return
  fi
  # 3. Config file in repo root
  if [[ -f "$root/.review-config" ]]; then
    local val
    val=$(grep -E '^REVIEWER=' "$root/.review-config" | tail -1 | cut -d= -f2 | tr -d '[:space:]')
    if [[ -n "$val" ]]; then
      echo "$val"
      return
    fi
  fi
  # 4. Auto-detect from repo files (backend-specific files hint at preferred backend)
  local -a file_hints=(
    ".github/copilot-instructions.md:copilot"
    "AGENTS.md:codex"
    "GEMINI.md:gemini"
    "CLAUDE.md:claude"
    ".claude/CLAUDE.md:claude"
  )
  for entry in "${file_hints[@]}"; do
    local file="${entry%%:*}" hint="${entry##*:}"
    if [[ -f "$root/$file" ]]; then
      case "$hint" in
        copilot)
          if command -v copilot &>/dev/null || command -v gh &>/dev/null; then
            echo "$hint"; return
          fi ;;
        *)
          if command -v "$hint" &>/dev/null; then
            echo "$hint"; return
          fi ;;
      esac
    fi
  done
  # 5. Fall back to first available CLI
  local -a candidates=(claude codex gemini opencode copilot)
  for cmd in "${candidates[@]}"; do
    case "$cmd" in
      copilot)
        if command -v copilot &>/dev/null || command -v gh &>/dev/null; then
          echo "copilot"; return
        fi ;;
      *)
        if command -v "$cmd" &>/dev/null; then
          echo "$cmd"; return
        fi ;;
    esac
  done
  echo ""
}

load_criteria() {
  local root="$1"
  # Read criteria path from .review-config
  if [[ -f "$root/.review-config" ]]; then
    local criteria_path
    criteria_path=$(grep -E '^CRITERIA=' "$root/.review-config" | tail -1 | cut -d= -f2 | tr -d '[:space:]')
    if [[ -n "$criteria_path" ]] && [[ -f "$root/$criteria_path" ]]; then
      cat "$root/$criteria_path"
      return
    fi
  fi
  # Fall back to the default criteria shipped with local-review
  if [[ -f "$SCRIPT_DIR/criteria.md" ]]; then
    cat "$SCRIPT_DIR/criteria.md"
  fi
}

build_input() {
  local prompt="$1" diff_file="$2" context_file="${3:-}"
  printf '%s\n\n' "$prompt"
  if [[ -n "$context_file" ]] && [[ -s "$context_file" ]]; then
    cat "$context_file"
    printf '\n\n'
  fi
  printf 'Diff (showing what changed):\n\n```diff\n'
  cat "$diff_file"
  printf '```'
}

build_file_context() {
  local diff_file="$1" root="$2" base_ref="${3:-}"
  local context_file
  context_file=$(mktemp)
  local files
  files=$(grep -E '^\+\+\+ b/' "$diff_file" | sed 's|^+++ b/||')
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    printf '=== %s ===\n\n' "$file" >> "$context_file"
    # Base version (before changes)
    if [[ -n "$base_ref" ]]; then
      local base_content
      base_content=$(git -C "$root" show "$base_ref:$file" 2>/dev/null) || base_content=""
      if [[ -n "$base_content" ]]; then
        {
          printf 'Before:\n```\n'
          printf '%s' "$base_content"
          printf '\n```\n\n'
        } >> "$context_file"
      else
        printf 'New file.\n\n' >> "$context_file"
      fi
    fi
    # Head version (current)
    if [[ -f "$root/$file" ]]; then
      {
        printf 'After:\n```\n'
        cat "$root/$file"
        printf '\n```\n\n'
      } >> "$context_file"
    else
      printf 'File deleted.\n\n' >> "$context_file"
    fi
  done <<< "$files"
  echo "$context_file"
}

resolve_model() {
  local model_override="$1" root="$2"
  if [[ -n "$model_override" ]]; then
    echo "$model_override"
    return
  fi
  if [[ -f "$root/.review-config" ]]; then
    local val
    val=$(grep -E '^MODEL=' "$root/.review-config" | tail -1 | cut -d= -f2 | tr -d '[:space:]')
    if [[ -n "$val" ]]; then
      echo "$val"
      return
    fi
  fi
}

run_backend() {
  local backend="$1" prompt="$2" diff_file="$3" root="$4" model="${5:-}" context_file="${6:-}"

  case "$backend" in
    claude)
      local flags=""
      if [[ -n "$model" ]]; then
        flags="--model $model"
      fi
      unset CLAUDECODE
      # shellcheck disable=SC2086
      build_input "$prompt" "$diff_file" "$context_file" \
        | claude -p --no-session-persistence --effort medium $flags
      ;;
    codex)
      if [[ -n "$model" ]]; then
        build_input "$prompt" "$diff_file" "$context_file" \
          | codex exec -c model="\"$model\"" -
      else
        build_input "$prompt" "$diff_file" "$context_file" \
          | codex exec -
      fi
      ;;
    gemini)
      local flags=""
      if [[ -n "$model" ]]; then
        flags="-m $model"
      fi
      # shellcheck disable=SC2086
      build_input "$prompt" "$diff_file" "$context_file" \
        | gemini -p $flags -
      ;;
    opencode)
      build_input "$prompt" "$diff_file" "$context_file" \
        | opencode -p -q
      ;;
    copilot)
      local copilot_cmd="copilot"
      if ! command -v copilot &>/dev/null; then
        if command -v gh &>/dev/null; then
          copilot_cmd="gh copilot"
        else
          echo "Neither copilot nor gh CLI found." >&2
          return 1
        fi
      fi
      local flags=""
      if [[ -n "$model" ]]; then
        flags="--model $model"
      fi
      # copilot only accepts prompt as -p argument (no stdin),
      # so skip file context to stay within ARG_MAX
      local input
      input=$(build_input "$prompt" "$diff_file" "")
      local raw_file
      raw_file=$(mktemp)
      # shellcheck disable=SC2086
      $copilot_cmd -p "$input" $flags > "$raw_file" 2>/dev/null
      # Strip usage stats footer
      sed '/^Total usage est:/,$d' "$raw_file" \
        | sed -e :a -e '/^\n*$/{$d;N;ba' -e '}'
      rm -f "$raw_file"
      ;;
    *)
      echo "Unknown backend: $backend" >&2
      echo "Supported: claude, codex, gemini, opencode, copilot" >&2
      return 1
      ;;
  esac
}

pipe_to_backend_interactive() {
  local backend="$1"
  shift
  case "$backend" in
    claude)   "$@" | claude ;;
    codex)    "$@" | codex ;;
    gemini)   "$@" | gemini ;;
    opencode) "$@" | opencode ;;
    copilot)
      local copilot_cmd="copilot"
      command -v copilot &>/dev/null || copilot_cmd="gh copilot"
      # shellcheck disable=SC2086
      "$@" | $copilot_cmd
      ;;
  esac
}

# --- Subcommand: setup ---

cmd_setup() {
  local install_dir="${XDG_DATA_HOME:-$HOME/.local/share}/local-review"
  local bin_dir="$HOME/.local/bin"

  if [[ "$SCRIPT_DIR" == "$install_dir" ]]; then
    echo "Already installed at $install_dir"
  else
    mkdir -p "$install_dir"
    cp "$SCRIPT_DIR/local-review" "$install_dir/local-review"
    chmod 755 "$install_dir/local-review"
    cp "$SCRIPT_DIR/criteria.md" "$install_dir/criteria.md"
    echo "Installed to $install_dir"
  fi

  mkdir -p "$bin_dir"
  ln -sf "$install_dir/local-review" "$bin_dir/local-review"
  echo "Symlinked $bin_dir/local-review"

  # Install slash commands globally (works in Claude Code and Copilot)
  local commands_dir="$HOME/.claude/commands"
  mkdir -p "$commands_dir"
  cp "$SCRIPT_DIR/local-review.md" "$commands_dir/local-review.md"
  cp "$SCRIPT_DIR/local-review-fix.md" "$commands_dir/local-review-fix.md"
  echo "Installed /local-review and /local-review-fix commands to $commands_dir"

  if ! echo "$PATH" | tr ':' '\n' | grep -qx "$bin_dir"; then
    echo ""
    echo "Add to your shell profile:"
    echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
  fi
}

# --- Subcommand: update ---

cmd_update() {
  local install_dir="${XDG_DATA_HOME:-$HOME/.local/share}/local-review"

  if ! git -C "$install_dir" rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Not a git checkout: $install_dir" >&2
    echo "Re-install with: git clone git@github.com:84codes/local-review.git $install_dir" >&2
    exit 1
  fi

  echo "Pulling latest..."
  git -C "$install_dir" pull --ff-only || {
    echo "Pull failed. Resolve manually in $install_dir" >&2
    exit 1
  }

  exec "$install_dir/local-review" setup
}

# --- Subcommand: install ---

cmd_install() {
  local force=false
  for arg in "$@"; do
    case "$arg" in
      --force) force=true ;;
      -h|--help)
        echo "Usage: $PROG install [--force]"
        echo "  Sets up thin wrappers and config in the current git repo."
        exit 0
        ;;
    esac
  done

  local root
  root=$(find_repo_root)

  local installed=()
  local skipped=()

  # --- Thin hook wrapper ---
  install_wrapper() {
    local dest="$root/$1" content="$2"
    if [[ -f "$dest" ]] && [[ "$force" != true ]]; then
      skipped+=("$1 (already exists)")
      return
    fi
    mkdir -p "$(dirname "$dest")"
    printf '%s\n' "$content" > "$dest"
    chmod 755 "$dest"
    installed+=("$1")
  }

  # --- Detect hook manager ---
  local hook_manager="none"
  if [[ -d "$root/.husky" ]]; then
    hook_manager="husky"
  elif [[ -f "$root/.overcommit.yml" ]]; then
    hook_manager="overcommit"
  fi

  local hook_wrapper
  hook_wrapper=$(cat <<'SH'
#!/usr/bin/env bash
command -v local-review &>/dev/null || exit 0
exec local-review hook "$@"
SH
)

  case "$hook_manager" in
    husky)
      local husky_file="$root/.husky/pre-push"
      local husky_guard="command -v local-review &>/dev/null && local-review hook"
      if [[ -f "$husky_file" ]] && grep -qF "local-review hook" "$husky_file"; then
        skipped+=(".husky/pre-push (already contains local-review)")
      elif [[ -f "$husky_file" ]] && [[ "$force" != true ]]; then
        printf '\n%s\n' "$husky_guard" >> "$husky_file"
        installed+=(".husky/pre-push (appended local-review hook)")
      else
        if [[ -d "$root/.husky/_" ]]; then
          # husky v8
          # shellcheck disable=SC2016
          printf '#!/bin/sh\n. "$(dirname "$0")/_/husky.sh"\n\n%s\n' "$husky_guard" > "$husky_file"
        else
          # husky v9+
          printf '%s\n' "$husky_guard" > "$husky_file"
        fi
        chmod 755 "$husky_file"
        installed+=(".husky/pre-push")
      fi
      ;;
    overcommit)
      local oc_config="$root/.overcommit.yml"
      if grep -q "local-review" "$oc_config" 2>/dev/null; then
        skipped+=(".overcommit.yml (already contains local-review)")
      else
        cat >> "$oc_config" <<'YAML'

PrePush:
  LocalReview:
    enabled: true
    command: ['local-review', 'hook']
    quiet: false
YAML
        installed+=(".overcommit.yml (added PrePush LocalReview)")
      fi
      ;;
    *)
      local git_common_dir
      git_common_dir=$(git -C "$root" rev-parse --git-common-dir)
      local hook_dest="$git_common_dir/hooks/pre-push"
      if [[ -f "$hook_dest" ]] && [[ "$force" != true ]]; then
        : # already exists, skip silently
      else
        mkdir -p "$(dirname "$hook_dest")"
        printf '%s\n' "$hook_wrapper" > "$hook_dest"
        chmod 755 "$hook_dest"
        installed+=("pre-push hook")
      fi
      ;;
  esac

  # --- Detect defaults for interactive prompts ---

  # Default backend: auto-detect from repo files, then installed CLIs
  local default_backend
  default_backend=$(resolve_backend "$root")

  # Default criteria: check existing config, then known files
  local default_criteria=""
  local -a known_criteria=(
    ".claude/review-criteria.md"
    ".github/copilot-instructions.md"
    "AGENTS.md"
    "GEMINI.md"
    "CLAUDE.md"
    ".claude/CLAUDE.md"
  )
  if [[ -f "$root/.review-config" ]]; then
    default_criteria=$(grep -E '^CRITERIA=' "$root/.review-config" 2>/dev/null | tail -1 | cut -d= -f2 | tr -d '[:space:]')
    [[ -n "$default_criteria" ]] && [[ ! -f "$root/$default_criteria" ]] && default_criteria=""
  fi
  if [[ -z "$default_criteria" ]]; then
    for candidate in "${known_criteria[@]}"; do
      if [[ -f "$root/$candidate" ]]; then
        default_criteria="$candidate"
        break
      fi
    done
  fi

  # --- Prompt for configuration ---
  echo ""
  local chosen_backend chosen_criteria chosen_model

  if [[ -n "$default_backend" ]]; then
    printf "  Backend [%s]: " "$default_backend"
  else
    printf "  Backend (claude, codex, gemini, opencode, copilot): "
  fi
  read -r chosen_backend
  chosen_backend="${chosen_backend:-$default_backend}"

  if [[ -n "$default_criteria" ]]; then
    printf "  Criteria [%s]: " "$default_criteria"
  else
    printf "  Criteria (path to review criteria file, or empty to create default): "
  fi
  read -r chosen_criteria
  chosen_criteria="${chosen_criteria:-$default_criteria}"

  # Default model: check existing config, then pick per-backend default
  local default_model=""
  if [[ -f "$root/.review-config" ]]; then
    default_model=$(grep -E '^MODEL=' "$root/.review-config" 2>/dev/null | tail -1 | cut -d= -f2 | tr -d '[:space:]')
  fi
  if [[ -z "$default_model" ]]; then
    case "$chosen_backend" in
      copilot) default_model="gpt-4.1" ;;
      *)       default_model="claude-sonnet-4-6" ;;
    esac
  fi

  printf "  Model [%s]: " "$default_model"
  read -r chosen_model
  chosen_model="${chosen_model:-$default_model}"

  echo ""

  # --- Create criteria file if needed ---
  if [[ -z "$chosen_criteria" ]]; then
    chosen_criteria=".claude/review-criteria.md"
    local dest_path="$root/$chosen_criteria"
    if [[ -f "$dest_path" ]] && [[ "$force" != true ]]; then
      skipped+=("$chosen_criteria (already exists)")
    else
      mkdir -p "$(dirname "$dest_path")"
      cp "$SCRIPT_DIR/criteria.md" "$dest_path"
      installed+=("$chosen_criteria")
    fi
  fi

  # --- Write .review-config ---
  local config_file="$root/.review-config"
  printf 'REVIEWER=%s\nCRITERIA=%s\nMODEL=%s\n' \
    "$chosen_backend" "$chosen_criteria" "$chosen_model" > "$config_file"
  installed+=(".review-config")

  # --- Summary ---
  if [[ ${#installed[@]} -gt 0 ]]; then
    for item in "${installed[@]}"; do
      echo "  + $item"
    done
  fi
  if [[ ${#installed[@]} -eq 0 ]]; then
    echo "Already configured, nothing to do."
  fi
}

# --- Subcommand: review ---

cmd_review() {
  local raw=false
  local fix=false
  local max_iterations=5
  local pr_number=""
  local reviewer_flag=""
  local model_flag=""
  local criteria_flag=""
  for arg in "$@"; do
    case "$arg" in
      --raw) raw=true ;;
      --fix) fix=true ;;
      --max=*) max_iterations="${arg#--max=}" ;;
      --reviewer=*) reviewer_flag="${arg#--reviewer=}" ;;
      --model=*) model_flag="${arg#--model=}" ;;
      --criteria=*) criteria_flag="${arg#--criteria=}" ;;
      -h|--help)
        echo "Usage: $PROG review [OPTIONS] [PR_NUMBER]"
        echo ""
        echo "Options:"
        echo "  --reviewer=BACKEND  Force backend (claude, codex, gemini, opencode, copilot)"
        echo "  --model=MODEL       Override model (backend-specific, e.g. claude-opus-4-6)"
        echo "  --criteria=FILE     Use custom criteria file instead of auto-detected"
        echo "  --fix               Review, fix, and re-review in a loop until clean"
        echo "  --max=N             Max iterations for --fix (default: 5)"
        echo "  --raw               Raw markdown output (no pager)"
        exit 0
        ;;
      *) pr_number="$arg" ;;
    esac
  done

  local root
  root=$(find_repo_root)

  # --reviewer flag takes highest priority
  if [[ -n "$reviewer_flag" ]]; then
    REVIEWER="$reviewer_flag"
  fi

  local backend
  backend=$(resolve_backend "$root")
  if [[ -z "$backend" ]]; then
    echo "No review backend found. Install one of: claude, codex, gemini, opencode, copilot" >&2
    exit 1
  fi

  if [[ "$fix" == true ]] && [[ "$backend" == "copilot" ]]; then
    echo "The --fix flag requires an agentic backend (claude, codex, gemini, opencode)." >&2
    exit 1
  fi

  local main_branch="${REVIEW_BASE_BRANCH:-main}"

  # For --fix with a PR number, checkout the branch first
  if [[ "$fix" == true ]] && [[ -n "$pr_number" ]]; then
    echo "Checking out PR #$pr_number..."
    command gh pr checkout "$pr_number" || {
      echo "Failed to checkout PR #$pr_number" >&2
      exit 1
    }
    # After checkout, review local diff instead of PR diff
    pr_number=""
  fi

  local model
  if [[ -n "$reviewer_flag" ]] && [[ -z "$model_flag" ]]; then
    # Backend was overridden; config model belongs to the config's backend
    model=""
  else
    model=$(resolve_model "$model_flag" "$root")
  fi

  local criteria
  if [[ -n "$criteria_flag" ]]; then
    if [[ ! -f "$criteria_flag" ]]; then
      echo "Criteria file not found: $criteria_flag" >&2
      exit 1
    fi
    criteria=$(cat "$criteria_flag")
  else
    criteria=$(load_criteria "$root")
  fi
  local review_prompt
  if [[ "$backend" == "copilot" ]]; then
    review_prompt="You are a code reviewer. You are given the before and after versions of each changed file, plus a diff showing what changed. Review the changes and provide feedback on problems.

Think step by step:
1. Read the full file content to understand context, then focus on the diff.
2. Identify where the change introduces a problem or can be improved.
3. Avoid commenting on correct code or commented-out code.
4. Reply with an enumerated list. Each item must include: line number, file path, kind (bug, performance, consistency, naming, readability, style, other), severity (low, medium, high), and a clear explanation.

Format: 1. Line 42 in src/foo.js, bug, high severity: description of the problem.

If no problems found, say \"No issues found.\"

$criteria"
  else
    review_prompt="Review the following changes. You are given the before and after versions of each changed file, plus a diff showing what changed. Report ONLY problems that need fixing.

$criteria"
  fi

  local iteration=0
  while true; do
    iteration=$((iteration + 1))

    if [[ "$fix" == true ]]; then
      echo "--- Review iteration $iteration/$max_iterations ---"
    fi

    # Get diff
    local diff_file
    diff_file=$(mktemp)

    if [[ -n "$pr_number" ]]; then
      if ! [[ "$pr_number" =~ ^[0-9]+$ ]]; then
        echo "Invalid PR number: $pr_number" >&2
        rm -f "$diff_file"
        exit 1
      fi
      command gh pr diff "$pr_number" > "$diff_file" || {
        echo "Failed to fetch diff for PR #$pr_number" >&2
        rm -f "$diff_file"
        exit 1
      }
    else
      local base
      base=$(git merge-base HEAD "origin/$main_branch")
      git diff "$base"...HEAD -- > "$diff_file"
    fi

    if [[ ! -s "$diff_file" ]]; then
      echo "No changes to review."
      rm -f "$diff_file"
      break
    fi

    # Build file context for changed files (base + head versions)
    local context_file=""
    if [[ -z "$pr_number" ]]; then
      context_file=$(build_file_context "$diff_file" "$root" "$base")
    fi

    # Run review
    local output_file
    output_file=$(mktemp)
    if [[ -n "$model" ]]; then
      printf "Reviewing with %s (%s)...\n" "$backend" "$model" >&2
    else
      printf "Reviewing with %s...\n" "$backend" >&2
    fi
    local start_time=$SECONDS
    run_backend "$backend" "$review_prompt" "$diff_file" "$root" "$model" "$context_file" > "$output_file"
    local rc=$?
    printf "Review complete (%ds)\n" "$((SECONDS - start_time))" >&2
    if (( rc != 0 )); then
      echo "Review failed ($backend exited $rc)" >&2
      rm -f "$diff_file" "$context_file" "$output_file"
      exit 1
    fi
    rm -f "$diff_file" "$context_file"

    # Display output
    if [[ "$raw" == true ]]; then
      cat "$output_file"
    elif [[ -t 1 ]] && command -v glow &>/dev/null; then
      glow --pager - < "$output_file"
    else
      cat "$output_file"
      if [[ -t 1 ]]; then
        echo "(tip: install glow for rendered markdown output)" >&2
      fi
    fi

    # Without --fix, single pass and done
    if [[ "$fix" != true ]]; then
      rm -f "$output_file"
      break
    fi

    # Check if clean
    if grep -qF "No issues found" "$output_file"; then
      rm -f "$output_file"
      echo "Clean after $iteration iteration(s)."
      break
    fi

    if (( iteration >= max_iterations )); then
      echo "Reached max iterations ($max_iterations). Issues may remain."
      rm -f "$output_file"
      break
    fi

    # Fix: pipe findings into the backend's interactive/agentic mode
    echo "Fixing issues..."
    local fix_prompt
    fix_prompt=$(printf '%s\n\n%s' \
      "Fix the following review findings in the codebase. Edit the files directly. Do not explain, just fix. If a finding is a false positive, skip it." \
      "$(cat "$output_file")")
    rm -f "$output_file"
    case "$backend" in
      claude)
        unset CLAUDECODE
        printf '%s' "$fix_prompt" | claude --no-session-persistence
        ;;
      codex)
        printf '%s' "$fix_prompt" | codex exec --auto-edit -
        ;;
      gemini)
        printf '%s' "$fix_prompt" | gemini --yolo -p -
        ;;
      opencode)
        printf '%s' "$fix_prompt" | opencode -p -q
        ;;
    esac || {
      echo "Fix step failed." >&2
      exit 1
    }
    echo ""
  done
}

# --- Subcommand: hook (pre-push) ---

cmd_hook() {
  local main_branch="${REVIEW_BASE_BRANCH:-main}"

  local base
  base=$(git merge-base HEAD "origin/$main_branch" 2>/dev/null || echo "")
  if [[ -z "$base" ]]; then
    exit 0
  fi

  local diff_file
  diff_file=$(mktemp)
  local review_file=""
  trap 'rm -f "$diff_file" "$review_file"' EXIT
  git diff "$base"...HEAD -- > "$diff_file"
  if [[ ! -s "$diff_file" ]]; then
    exit 0
  fi

  local root
  root=$(find_repo_root)

  local backend
  backend=$(resolve_backend "$root")
  if [[ -z "$backend" ]]; then
    echo "No review backend found, skipping review"
    exit 0
  fi

  local criteria
  criteria=$(load_criteria "$root")

  # Inside a Claude Code session: emit to stderr for interactive review
  if [[ -n "${CLAUDECODE:-}" ]]; then
    {
      printf '%s\n\n%s\n\n```diff\n' \
        "Review the following diff and report ONLY problems that need fixing." \
        "$criteria"
      cat "$diff_file"
      printf '```\n\n---\nINSTRUCTION: The push was intentionally blocked by the review hook.\nReview the diff above against the criteria. Present each finding to the user one by one.\nAsk for approval before making any changes. Do not fix anything without explicit user confirmation.\nIf there are no issues, tell the user and push with --no-verify to bypass the hook.\n'
    } >&2
    exit 1
  fi

  # Ask interactive terminal users if they want to run the review
  if [[ -e /dev/tty ]]; then
    local answer
    read -r -p "Run AI review before pushing? [Y/n] " answer </dev/tty 2>/dev/tty || answer="y"
    if [[ "$answer" =~ ^[Nn]$ ]]; then
      exit 0
    fi
  fi

  # Run review
  echo "Running $backend review before push..."
  review_file=$(mktemp)
  REVIEWER="$backend" "$PROG" review --raw > "$review_file"
  if command -v glow &>/dev/null; then
    glow --pager - < "$review_file"
  else
    cat "$review_file"
    if [[ -t 1 ]]; then
      echo "(tip: install glow for rendered markdown output)" >&2
    fi
  fi

  # Let the user decide
  if ! grep -qF "No issues found" "$review_file"; then
    echo ""
    echo "Issues found. What do you want to do?"
    echo "  1) Push anyway"
    echo "  2) Abort"
    echo "  3) Address interactively"
    local choice
    read -r -p "Choice [1-3]: " choice </dev/tty 2>/dev/tty || choice="2"
    case "$choice" in
      1) exit 0 ;;
      3)
        pipe_to_backend_interactive "$backend" \
          printf '%s\n\n%s' "Here are the review findings. Ask me what to address." "$(cat "$review_file")"
        echo "When ready, run: git push --no-verify" >&2
        exit 1
        ;;
      *) exit 1 ;;
    esac
  fi

  exit 0
}

# --- Main dispatch ---

case "${1:-}" in
  setup)   shift; cmd_setup "$@" ;;
  update)  shift; cmd_update "$@" ;;
  install) shift; cmd_install "$@" ;;
  review)  shift; cmd_review "$@" ;;
  hook)    shift; cmd_hook "$@" ;;
  -h|--help)
    echo "Usage: $PROG [OPTIONS] [PR_NUMBER]"
    echo "       $PROG <command> [options]"
    echo ""
    echo "Running without a command defaults to review."
    echo ""
    echo "Commands:"
    echo "  setup    Install local-review for your user (~/.local/bin)"
    echo "  update   Pull latest changes and re-run setup"
    echo "  install  Set up thin wrappers and config in current git repo"
    echo "  review   Run a code review (default command)"
    echo "  hook     Pre-push hook logic (called by git)"
    echo ""
    echo "Run '$PROG review --help' for review options."
    echo "Version: $VERSION"
    ;;
  --version) echo "$PROG $VERSION" ;;
  *)
    # Default to review for unrecognized args (flags, PR numbers, etc.)
    cmd_review "$@"
    ;;
esac
