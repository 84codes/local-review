#!/usr/bin/env bash
set -euo pipefail

# local-review: AI-powered local code review for git repos.
# Subcommands: setup, install, review, hook

PROG="local-review"
VERSION="0.1.0"

# --- Shared helpers ---

find_repo_root() {
  git rev-parse --show-toplevel 2>/dev/null || {
    echo "Not inside a git repository." >&2
    exit 1
  }
}

resolve_backend() {
  local root="$1"
  # 1. CLI flag (set via REVIEWER before calling)
  # 2. Environment variable
  if [[ -n "${REVIEWER:-}" ]]; then
    echo "$REVIEWER"
    return
  fi
  # 3. Config file in repo root
  if [[ -f "$root/.review-config" ]]; then
    local val
    val=$(grep -E '^REVIEWER=' "$root/.review-config" | tail -1 | cut -d= -f2 | tr -d '[:space:]')
    if [[ -n "$val" ]]; then
      echo "$val"
      return
    fi
  fi
  # 4. Auto-detect: prefer claude, then others
  local -a candidates=(claude codex gemini opencode copilot)
  for cmd in "${candidates[@]}"; do
    case "$cmd" in
      copilot)
        if command -v copilot &>/dev/null || command -v gh &>/dev/null; then
          echo "copilot"; return
        fi ;;
      *)
        if command -v "$cmd" &>/dev/null; then
          echo "$cmd"; return
        fi ;;
    esac
  done
  echo ""
}

load_criteria() {
  local root="$1"
  if [[ -f "$root/.claude/review-criteria.md" ]]; then
    cat "$root/.claude/review-criteria.md"
  elif [[ -f "$root/.github/review-criteria.md" ]]; then
    cat "$root/.github/review-criteria.md"
  else
    # Fall back to the default criteria shipped with local-review
    local source_dir
    source_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
    if [[ -f "$source_dir/criteria.md" ]]; then
      cat "$source_dir/criteria.md"
    fi
  fi
}

build_input() {
  local prompt="$1" diff_file="$2"
  printf '%s\n\n```diff\n' "$prompt"
  cat "$diff_file"
  printf '```'
}

resolve_model() {
  local model_override="$1" root="$2"
  if [[ -n "$model_override" ]]; then
    echo "$model_override"
    return
  fi
  local model_file="$root/.claude/review-model"
  if [[ -f "$model_file" ]]; then
    tr -d '[:space:]' < "$model_file"
  fi
}

run_backend() {
  local backend="$1" prompt="$2" diff_file="$3" root="$4" model="${5:-}"

  case "$backend" in
    claude)
      local flags=""
      if [[ -n "$model" ]]; then
        flags="--model $model"
      fi
      unset CLAUDECODE
      # shellcheck disable=SC2086
      build_input "$prompt" "$diff_file" \
        | claude -p --no-session-persistence --effort medium $flags
      ;;
    codex)
      if [[ -n "$model" ]]; then
        build_input "$prompt" "$diff_file" \
          | codex exec -c model="\"$model\"" -
      else
        build_input "$prompt" "$diff_file" \
          | codex exec -
      fi
      ;;
    gemini)
      local flags=""
      if [[ -n "$model" ]]; then
        flags="-m $model"
      fi
      # shellcheck disable=SC2086
      build_input "$prompt" "$diff_file" \
        | gemini -p $flags -
      ;;
    opencode)
      build_input "$prompt" "$diff_file" \
        | opencode -p -q
      ;;
    copilot)
      local copilot_cmd="copilot"
      if ! command -v copilot &>/dev/null; then
        if command -v gh &>/dev/null; then
          copilot_cmd="gh copilot"
        else
          echo "Neither copilot nor gh CLI found." >&2
          return 1
        fi
      fi
      # shellcheck disable=SC2086
      build_input "$prompt" "$diff_file" \
        | $copilot_cmd
      ;;
    *)
      echo "Unknown backend: $backend" >&2
      echo "Supported: claude, codex, gemini, opencode, copilot" >&2
      return 1
      ;;
  esac
}

pipe_to_backend_interactive() {
  local backend="$1"
  shift
  case "$backend" in
    claude)   "$@" | claude ;;
    codex)    "$@" | codex ;;
    gemini)   "$@" | gemini ;;
    opencode) "$@" | opencode ;;
    copilot)
      local copilot_cmd="copilot"
      command -v copilot &>/dev/null || copilot_cmd="gh copilot"
      # shellcheck disable=SC2086
      "$@" | $copilot_cmd
      ;;
  esac
}

# --- Subcommand: setup ---

cmd_setup() {
  local install_dir="${XDG_DATA_HOME:-$HOME/.local/share}/local-review"
  local bin_dir="$HOME/.local/bin"

  # Resolve where this script lives (the repo checkout)
  local source_dir
  source_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

  if [[ "$source_dir" == "$install_dir" ]]; then
    echo "Already installed at $install_dir"
  else
    mkdir -p "$install_dir"
    cp "$source_dir/local-review" "$install_dir/local-review"
    chmod 755 "$install_dir/local-review"
    cp "$source_dir/criteria.md" "$install_dir/criteria.md"
    echo "Installed to $install_dir"
  fi

  mkdir -p "$bin_dir"
  ln -sf "$install_dir/local-review" "$bin_dir/local-review"
  echo "Symlinked $bin_dir/local-review"

  # Install Claude Code slash commands globally
  local commands_dir="$HOME/.claude/commands"
  mkdir -p "$commands_dir"
  cp "$source_dir/local-review.md" "$commands_dir/local-review.md"
  cp "$source_dir/local-review-fix.md" "$commands_dir/local-review-fix.md"
  echo "Installed /local-review and /local-review-fix commands to $commands_dir"

  if ! echo "$PATH" | tr ':' '\n' | grep -qx "$bin_dir"; then
    echo ""
    echo "Add to your shell profile:"
    echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
  fi
}

# --- Subcommand: install ---

cmd_install() {
  local force=false
  for arg in "$@"; do
    case "$arg" in
      --force) force=true ;;
      -h|--help)
        echo "Usage: $PROG install [--force]"
        echo "  Sets up thin wrappers and config in the current git repo."
        exit 0
        ;;
    esac
  done

  local root
  root=$(find_repo_root)

  # Resolve where criteria.md lives (next to this script)
  local source_dir
  source_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

  local installed=()
  local skipped=()

  # --- Thin wrapper: .githooks/pre-push ---
  install_wrapper() {
    local dest="$root/$1" content="$2"
    if [[ -f "$dest" ]] && [[ "$force" != true ]]; then
      skipped+=("$1 (already exists)")
      return
    fi
    mkdir -p "$(dirname "$dest")"
    printf '%s\n' "$content" > "$dest"
    chmod 755 "$dest"
    installed+=("$1")
  }

  # --- Detect hook manager ---
  local hook_manager="none"
  if [[ -d "$root/.husky" ]]; then
    hook_manager="husky"
  elif [[ -f "$root/.overcommit.yml" ]]; then
    hook_manager="overcommit"
  fi

  local hook_wrapper
  hook_wrapper=$(cat <<'SH'
#!/usr/bin/env bash
exec local-review hook "$@"
SH
)

  case "$hook_manager" in
    husky)
      local husky_file="$root/.husky/pre-push"
      local husky_line="local-review hook"
      if [[ -f "$husky_file" ]] && grep -qF "$husky_line" "$husky_file"; then
        skipped+=(".husky/pre-push (already contains local-review)")
      elif [[ -f "$husky_file" ]] && [[ "$force" != true ]]; then
        printf '\n%s\n' "$husky_line" >> "$husky_file"
        installed+=(".husky/pre-push (appended local-review hook)")
      else
        if [[ -d "$root/.husky/_" ]]; then
          # husky v8
          # shellcheck disable=SC2016
          printf '#!/bin/sh\n. "$(dirname "$0")/_/husky.sh"\n\n%s\n' "$husky_line" > "$husky_file"
        else
          # husky v9+
          printf '%s\n' "$husky_line" > "$husky_file"
        fi
        chmod 755 "$husky_file"
        installed+=(".husky/pre-push")
      fi
      ;;
    overcommit)
      local oc_config="$root/.overcommit.yml"
      if grep -q "local-review" "$oc_config" 2>/dev/null; then
        skipped+=(".overcommit.yml (already contains local-review)")
      else
        cat >> "$oc_config" <<'YAML'

PrePush:
  LocalReview:
    enabled: true
    command: ['local-review', 'hook']
    quiet: false
YAML
        installed+=(".overcommit.yml (added PrePush LocalReview)")
      fi
      ;;
    *)
      install_wrapper ".githooks/pre-push" "$hook_wrapper"
      local current_hooks
      current_hooks=$(git -C "$root" config --get core.hooksPath 2>/dev/null || echo "")
      if [[ "$current_hooks" != ".githooks" ]]; then
        git -C "$root" config core.hooksPath .githooks
        installed+=("git config core.hooksPath .githooks")
      else
        skipped+=("git config core.hooksPath (already set)")
      fi
      ;;
  esac

  # --- Config files (repo-specific, won't overwrite) ---
  install_config() {
    local src="$1" dest="$2"
    local dest_path="$root/$dest"
    if [[ -f "$dest_path" ]] && [[ "$force" != true ]]; then
      skipped+=("$dest (already exists)")
      return
    fi
    mkdir -p "$(dirname "$dest_path")"
    cp "$src" "$dest_path"
    installed+=("$dest")
  }

  install_config "$source_dir/criteria.md" ".claude/review-criteria.md"
  install_config "$source_dir/criteria.md" ".github/copilot-instructions.md"

  if [[ ! -f "$root/.claude/review-model" ]] || [[ "$force" == true ]]; then
    mkdir -p "$root/.claude"
    echo "claude-sonnet-4-6" > "$root/.claude/review-model"
    installed+=(".claude/review-model")
  else
    skipped+=(".claude/review-model (already exists)")
  fi

  # --- Summary ---
  echo "$PROG installed in $root"
  if [[ "$hook_manager" != "none" ]]; then
    echo "Detected hook manager: $hook_manager"
  fi
  echo ""
  if [[ ${#installed[@]} -gt 0 ]]; then
    echo "Installed:"
    for item in "${installed[@]}"; do
      echo "  + $item"
    done
  fi
  if [[ ${#skipped[@]} -gt 0 ]]; then
    echo "Skipped:"
    for item in "${skipped[@]}"; do
      echo "  - $item"
    done
  fi
  echo ""
  echo "Configure backend in .review-config: REVIEWER=claude (or codex, gemini, opencode, copilot)"
  echo "Or use --reviewer flag, REVIEWER env var, or auto-detect."
}

# --- Subcommand: review ---

cmd_review() {
  local raw=false
  local fix=false
  local max_iterations=5
  local pr_number=""
  local reviewer_flag=""
  local model_flag=""
  local criteria_flag=""
  for arg in "$@"; do
    case "$arg" in
      --raw) raw=true ;;
      --fix) fix=true ;;
      --max=*) max_iterations="${arg#--max=}" ;;
      --reviewer=*) reviewer_flag="${arg#--reviewer=}" ;;
      --model=*) model_flag="${arg#--model=}" ;;
      --criteria=*) criteria_flag="${arg#--criteria=}" ;;
      -h|--help)
        echo "Usage: $PROG review [OPTIONS] [PR_NUMBER]"
        echo ""
        echo "Options:"
        echo "  --reviewer=BACKEND  Force backend (claude, codex, gemini, opencode, copilot)"
        echo "  --model=MODEL       Override model (backend-specific, e.g. claude-opus-4-6)"
        echo "  --criteria=FILE     Use custom criteria file instead of auto-detected"
        echo "  --fix               Review, fix, and re-review in a loop until clean"
        echo "  --max=N             Max iterations for --fix (default: 5)"
        echo "  --raw               Raw markdown output (no pager)"
        exit 0
        ;;
      *) pr_number="$arg" ;;
    esac
  done

  local root
  root=$(find_repo_root)

  # --reviewer flag takes highest priority
  if [[ -n "$reviewer_flag" ]]; then
    REVIEWER="$reviewer_flag"
  fi

  local backend
  backend=$(resolve_backend "$root")
  if [[ -z "$backend" ]]; then
    echo "No review backend found. Install one of: claude, codex, gemini, opencode, copilot" >&2
    exit 1
  fi

  if [[ "$fix" == true ]] && [[ "$backend" == "copilot" ]]; then
    echo "The --fix flag requires an agentic backend (claude, codex, gemini, opencode)." >&2
    exit 1
  fi

  local main_branch="${REVIEW_BASE_BRANCH:-main}"

  # For --fix with a PR number, checkout the branch first
  if [[ "$fix" == true ]] && [[ -n "$pr_number" ]]; then
    echo "Checking out PR #$pr_number..."
    command gh pr checkout "$pr_number" || {
      echo "Failed to checkout PR #$pr_number" >&2
      exit 1
    }
    # After checkout, review local diff instead of PR diff
    pr_number=""
  fi

  local model
  model=$(resolve_model "$model_flag" "$root")

  local criteria
  if [[ -n "$criteria_flag" ]]; then
    if [[ ! -f "$criteria_flag" ]]; then
      echo "Criteria file not found: $criteria_flag" >&2
      exit 1
    fi
    criteria=$(cat "$criteria_flag")
  else
    criteria=$(load_criteria "$root")
  fi
  local review_prompt="Review the following diff and report ONLY problems that need fixing.

$criteria"

  local iteration=0
  while true; do
    iteration=$((iteration + 1))

    if [[ "$fix" == true ]]; then
      echo "--- Review iteration $iteration/$max_iterations ---"
    fi

    # Get diff
    local diff_file
    diff_file=$(mktemp)

    if [[ -n "$pr_number" ]]; then
      if ! [[ "$pr_number" =~ ^[0-9]+$ ]]; then
        echo "Invalid PR number: $pr_number" >&2
        rm -f "$diff_file"
        exit 1
      fi
      command gh pr diff "$pr_number" > "$diff_file" || {
        echo "Failed to fetch diff for PR #$pr_number" >&2
        rm -f "$diff_file"
        exit 1
      }
    else
      local base
      base=$(git merge-base HEAD "origin/$main_branch")
      git diff "$base"...HEAD -- > "$diff_file"
    fi

    if [[ ! -s "$diff_file" ]]; then
      echo "No changes to review."
      rm -f "$diff_file"
      break
    fi

    # Run review
    local output
    output=$(run_backend "$backend" "$review_prompt" "$diff_file" "$root" "$model") || {
      echo "Review failed ($backend exited $?)" >&2
      rm -f "$diff_file"
      exit 1
    }
    rm -f "$diff_file"

    # Display output
    if [[ "$raw" == true ]]; then
      echo "$output"
    elif [[ -t 1 ]] && command -v glow &>/dev/null; then
      echo "$output" | glow --pager -
    else
      echo "$output"
      if [[ -t 1 ]]; then
        echo "(tip: install glow for rendered markdown output)" >&2
      fi
    fi

    # Without --fix, single pass and done
    if [[ "$fix" != true ]]; then
      break
    fi

    # Check if clean
    if echo "$output" | grep -qF "No issues found"; then
      echo "Clean after $iteration iteration(s)."
      break
    fi

    if (( iteration >= max_iterations )); then
      echo "Reached max iterations ($max_iterations). Issues may remain."
      break
    fi

    # Fix: pipe findings into the backend's interactive/agentic mode
    echo "Fixing issues..."
    local fix_prompt
    fix_prompt=$(printf '%s\n\n%s' \
      "Fix the following review findings in the codebase. Edit the files directly. Do not explain, just fix. If a finding is a false positive, skip it." \
      "$output")
    case "$backend" in
      claude)
        unset CLAUDECODE
        printf '%s' "$fix_prompt" | claude --no-session-persistence
        ;;
      codex)
        printf '%s' "$fix_prompt" | codex exec --auto-edit -
        ;;
      gemini)
        printf '%s' "$fix_prompt" | gemini --yolo -p -
        ;;
      opencode)
        printf '%s' "$fix_prompt" | opencode -p -q
        ;;
    esac || {
      echo "Fix step failed." >&2
      exit 1
    }
    echo ""
  done
}

# --- Subcommand: hook (pre-push) ---

cmd_hook() {
  local main_branch="${REVIEW_BASE_BRANCH:-main}"

  local base
  base=$(git merge-base HEAD "origin/$main_branch" 2>/dev/null || echo "")
  if [[ -z "$base" ]]; then
    exit 0
  fi

  local diff_file
  diff_file=$(mktemp)
  local review_file=""
  trap 'rm -f "$diff_file" "$review_file"' EXIT
  git diff "$base"...HEAD -- > "$diff_file"
  if [[ ! -s "$diff_file" ]]; then
    exit 0
  fi

  local root
  root=$(find_repo_root)

  local backend
  backend=$(resolve_backend "$root")
  if [[ -z "$backend" ]]; then
    echo "No review backend found, skipping review"
    exit 0
  fi

  local criteria
  criteria=$(load_criteria "$root")

  # Inside a Claude Code session: emit to stderr for interactive review
  if [[ -n "${CLAUDECODE:-}" ]]; then
    {
      printf '%s\n\n%s\n\n```diff\n' \
        "Review the following diff and report ONLY problems that need fixing." \
        "$criteria"
      cat "$diff_file"
      printf '```\n\n---\nINSTRUCTION: The push was intentionally blocked by the review hook.\nReview the diff above against the criteria. Present each finding to the user one by one.\nAsk for approval before making any changes. Do not fix anything without explicit user confirmation.\nIf there are no issues, tell the user and push with --no-verify to bypass the hook.\n'
    } >&2
    exit 1
  fi

  # Ask interactive terminal users if they want to run the review
  if [[ -e /dev/tty ]]; then
    local answer
    read -r -p "Run AI review before pushing? [Y/n] " answer </dev/tty 2>/dev/tty || answer="y"
    if [[ "$answer" =~ ^[Nn]$ ]]; then
      exit 0
    fi
  fi

  # Run review
  echo "Running $backend review before push..."
  review_file=$(mktemp)
  REVIEWER="$backend" "$PROG" review --raw > "$review_file"
  if command -v glow &>/dev/null; then
    glow --pager - < "$review_file"
  else
    cat "$review_file"
    if [[ -t 1 ]]; then
      echo "(tip: install glow for rendered markdown output)" >&2
    fi
  fi

  # Let the user decide
  if ! grep -qF "No issues found" "$review_file"; then
    echo ""
    echo "Issues found. What do you want to do?"
    echo "  1) Push anyway"
    echo "  2) Abort"
    echo "  3) Address interactively"
    local choice
    read -r -p "Choice [1-3]: " choice </dev/tty 2>/dev/tty || choice="2"
    case "$choice" in
      1) exit 0 ;;
      3)
        pipe_to_backend_interactive "$backend" \
          printf '%s\n\n%s' "Here are the review findings. Ask me what to address." "$(cat "$review_file")"
        echo "When ready, run: git push --no-verify" >&2
        exit 1
        ;;
      *) exit 1 ;;
    esac
  fi
}

# --- Main dispatch ---

case "${1:-}" in
  setup)   shift; cmd_setup "$@" ;;
  install) shift; cmd_install "$@" ;;
  review)  shift; cmd_review "$@" ;;
  hook)    shift; cmd_hook "$@" ;;
  -h|--help)
    echo "Usage: $PROG [OPTIONS] [PR_NUMBER]"
    echo "       $PROG <command> [options]"
    echo ""
    echo "Running without a command defaults to review."
    echo ""
    echo "Commands:"
    echo "  setup    Install local-review for your user (~/.local/bin)"
    echo "  install  Set up thin wrappers and config in current git repo"
    echo "  review   Run a code review (default command)"
    echo "  hook     Pre-push hook logic (called by git)"
    echo ""
    echo "Run '$PROG review --help' for review options."
    echo "Version: $VERSION"
    ;;
  --version) echo "$PROG $VERSION" ;;
  *)
    # Default to review for unrecognized args (flags, PR numbers, etc.)
    cmd_review "$@"
    ;;
esac
