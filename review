#!/usr/bin/env bash
set -euo pipefail

# Run an AI-powered code review locally.
# Usage:
#   extras/review          -- review local changes not yet on main
#   extras/review <pr>     -- review a specific PR number
#   extras/review --raw    -- output raw markdown (no pager)

RAW=false
PR_NUMBER=""
for arg in "$@"; do
  case "$arg" in
    --raw) RAW=true ;;
    *) PR_NUMBER="$arg" ;;
  esac
done

ROOT="$(git rev-parse --show-toplevel)"

# --- Backend selection ---
resolve_backend() {
  # 1. Environment variable
  if [[ -n "${REVIEWER:-}" ]]; then
    echo "$REVIEWER"
    return
  fi
  # 2. Config file in repo root
  if [[ -f "$ROOT/.review-config" ]]; then
    local val
    val=$(grep -E '^REVIEWER=' "$ROOT/.review-config" | tail -1 | cut -d= -f2 | tr -d '[:space:]')
    if [[ -n "$val" ]]; then
      echo "$val"
      return
    fi
  fi
  # 3. Auto-detect: prefer claude, fall back to copilot
  if command -v claude &>/dev/null; then
    echo "claude"
  elif command -v copilot &>/dev/null || command -v gh &>/dev/null; then
    echo "copilot"
  else
    echo ""
  fi
}

BACKEND=$(resolve_backend)
if [[ -z "$BACKEND" ]]; then
  echo "No review backend found. Install claude CLI or copilot CLI." >&2
  exit 1
fi

# --- Diff ---
DIFF_FILE=$(mktemp)
trap 'rm -f "$DIFF_FILE"' EXIT

MAIN_BRANCH="${REVIEW_BASE_BRANCH:-main}"

if [[ -n "$PR_NUMBER" ]]; then
  if ! [[ "$PR_NUMBER" =~ ^[0-9]+$ ]]; then
    echo "Invalid PR number: $PR_NUMBER" >&2
    exit 1
  fi
  command gh pr diff "$PR_NUMBER" > "$DIFF_FILE" || {
    echo "Failed to fetch diff for PR #$PR_NUMBER" >&2
    exit 1
  }
else
  BASE=$(git merge-base HEAD "origin/$MAIN_BRANCH")
  git diff "$BASE"...HEAD -- > "$DIFF_FILE"
fi

if [[ ! -s "$DIFF_FILE" ]]; then
  echo "No changes to review."
  exit 0
fi

# --- Criteria ---
CRITERIA=""
if [[ -f "$ROOT/.claude/review-criteria.md" ]]; then
  CRITERIA=$(cat "$ROOT/.claude/review-criteria.md")
elif [[ -f "$ROOT/.github/review-criteria.md" ]]; then
  CRITERIA=$(cat "$ROOT/.github/review-criteria.md")
fi

PROMPT="Review the following diff and report ONLY problems that need fixing.

$CRITERIA"

# --- Run review ---
run_claude() {
  local model_file="$ROOT/.claude/review-model"
  local model_flag=""
  if [[ -f "$model_file" ]]; then
    local model
    model=$(tr -d '[:space:]' < "$model_file")
    model_flag="--model $model"
  fi

  # Prevent nested Claude Code sessions (claude -p hangs inside CLAUDECODE)
  unset CLAUDECODE
  # shellcheck disable=SC2086
  { printf '%s\n\n```diff\n' "$PROMPT"; cat "$DIFF_FILE"; printf '```'; } \
    | claude -p --no-session-persistence --effort medium $model_flag
}

run_copilot() {
  local copilot_cmd=""
  if command -v copilot &>/dev/null; then
    copilot_cmd="copilot"
  elif command -v gh &>/dev/null; then
    copilot_cmd="gh copilot"
  else
    echo "Neither copilot nor gh CLI found." >&2
    exit 1
  fi

  { printf '%s\n\n```diff\n' "$PROMPT"; cat "$DIFF_FILE"; printf '```'; } \
    | $copilot_cmd
}

OUTPUT=""
case "$BACKEND" in
  claude)
    OUTPUT=$(run_claude) || { echo "Review failed (claude exited $?)" >&2; exit 1; }
    ;;
  copilot)
    OUTPUT=$(run_copilot) || { echo "Review failed (copilot exited $?)" >&2; exit 1; }
    ;;
  *)
    echo "Unknown backend: $BACKEND (use 'claude' or 'copilot')" >&2
    exit 1
    ;;
esac

# --- Output ---
if [[ "$RAW" == true ]]; then
  echo "$OUTPUT"
elif [[ -t 1 ]] && command -v glow &>/dev/null; then
  echo "$OUTPUT" | glow --pager -
else
  echo "$OUTPUT"
  if [[ -t 1 ]]; then
    echo "(tip: install glow for rendered markdown output)" >&2
  fi
fi
