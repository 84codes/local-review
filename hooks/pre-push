#!/usr/bin/env bash
set -euo pipefail

MAIN_BRANCH="${REVIEW_BASE_BRANCH:-main}"

# Skip if we can't find a common ancestor with main (e.g. orphan branch)
BASE=$(git merge-base HEAD "origin/$MAIN_BRANCH" 2>/dev/null || echo "")
if [[ -z "$BASE" ]]; then
  exit 0
fi

# Write diff to temp file to avoid unbounded shell variables
DIFF_FILE=$(mktemp)
REVIEW_FILE=""
trap 'rm -f "$DIFF_FILE" "$REVIEW_FILE"' EXIT
git diff "$BASE"...HEAD -- > "$DIFF_FILE"
if [[ ! -s "$DIFF_FILE" ]]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"

# --- Backend selection ---
resolve_backend() {
  if [[ -n "${REVIEWER:-}" ]]; then
    echo "$REVIEWER"
    return
  fi
  if [[ -f "$ROOT/.review-config" ]]; then
    local val
    val=$(grep -E '^REVIEWER=' "$ROOT/.review-config" | tail -1 | cut -d= -f2 | tr -d '[:space:]')
    if [[ -n "$val" ]]; then
      echo "$val"
      return
    fi
  fi
  if command -v claude &>/dev/null; then
    echo "claude"
  elif command -v copilot &>/dev/null || command -v gh &>/dev/null; then
    echo "copilot"
  else
    echo ""
  fi
}

BACKEND=$(resolve_backend)
if [[ -z "$BACKEND" ]]; then
  echo "No review backend found, skipping review"
  exit 0
fi

# --- Load criteria ---
CRITERIA=""
if [[ -f "$ROOT/.claude/review-criteria.md" ]]; then
  CRITERIA=$(cat "$ROOT/.claude/review-criteria.md")
elif [[ -f "$ROOT/.github/review-criteria.md" ]]; then
  CRITERIA=$(cat "$ROOT/.github/review-criteria.md")
fi

# --- Claude Code session: emit to stderr for interactive review ---
if [[ -n "${CLAUDECODE:-}" ]]; then
  {
    printf '%s\n\n%s\n\n```diff\n' \
      "Review the following diff and report ONLY problems that need fixing." \
      "$CRITERIA"
    cat "$DIFF_FILE"
    printf '```\n\n---\nINSTRUCTION: The push was intentionally blocked by the review hook.\nReview the diff above against the criteria. Present each finding to the user one by one.\nAsk for approval before making any changes. Do not fix anything without explicit user confirmation.\nIf there are no issues, tell the user and push with --no-verify to bypass the hook.\n'
  } >&2
  exit 1
fi

# --- Ask interactive terminal users if they want to run the review ---
if [[ -e /dev/tty ]]; then
  read -r -p "Run AI review before pushing? [Y/n] " answer </dev/tty 2>/dev/tty || answer="y"
  if [[ "$answer" =~ ^[Nn]$ ]]; then
    exit 0
  fi
fi

# --- Run the review script and render output ---
echo "Running $BACKEND review before push..."
REVIEW_FILE=$(mktemp)
REVIEWER="$BACKEND" "$ROOT/extras/review" --raw > "$REVIEW_FILE"
if command -v glow &>/dev/null; then
  glow --pager - < "$REVIEW_FILE"
else
  cat "$REVIEW_FILE"
  if [[ -t 1 ]]; then
    echo "(tip: install glow for rendered markdown output)" >&2
  fi
fi

# --- Let the user decide what to do with the findings ---
if ! grep -qF "No issues found" "$REVIEW_FILE"; then
  echo ""
  echo "Issues found. What do you want to do?"
  echo "  1) Push anyway"
  echo "  2) Abort"
  echo "  3) Address interactively"
  read -r -p "Choice [1-3]: " choice </dev/tty 2>/dev/tty || choice="2"
  case "$choice" in
    1) exit 0 ;;
    3)
      case "$BACKEND" in
        claude)
          { printf 'Here are the review findings. Ask me what to address.\n\n'; cat "$REVIEW_FILE"; } | claude
          ;;
        copilot)
          copilot_cmd="copilot"
          command -v copilot &>/dev/null || copilot_cmd="gh copilot"
          { printf 'Here are the review findings. Ask me what to address.\n\n'; cat "$REVIEW_FILE"; } | $copilot_cmd
          ;;
      esac
      echo "When ready, run: git push --no-verify" >&2
      exit 1
      ;;
    *) exit 1 ;;
  esac
fi
